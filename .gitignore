# Git ignore file for TechAcademy Monorepo

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Build outputs
dist/
build/
backend/main
backend/main.exe
*.exe
*.exe~
*.dll
*.so
*.dylib

# Databases (SQLite database generated at runtime)
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-wal
*.db

# Test reports & configs
test-results/
playwright-report/
blob-report/
playwright/.local-browsers/
.pytest_cache/

# IDE and System files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Document files
*.xlsx
*.docx